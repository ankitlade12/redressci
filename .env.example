# Optional. The complete synthetic judge demo runs without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
REDRESSCI_AI_RATE_LIMIT_PER_HOUR=20
PORT=8787

# Production-mode controls. Keep secrets in your host's secret manager.
REDRESSCI_PERSIST=
REDRESSCI_AUTH_SECRET=
REDRESSCI_AUTH_REQUIRED=
REDRESSCI_STORAGE_KEY=
REDRESSCI_ESCROW_KEY=
# PEM Ed25519 private key; use literal \n when stored on one line.
REDRESSCI_SIGNING_PRIVATE_KEY=
REDRESSCI_STORAGE_REGION=us

# Comma-separated HTTPS hostnames permitted for live target adapters.
REDRESSCI_TARGET_ALLOWLIST=
REDRESSCI_TARGET_TOKEN=
REDRESSCI_TARGET_API_KEY=

# Optional GitHub Checks API delivery. Use a GitHub App installation token in production.
REDRESSCI_GITHUB_REPOSITORY=
REDRESSCI_GITHUB_TOKEN=
REDRESSCI_RELEASE_WEBHOOK=
